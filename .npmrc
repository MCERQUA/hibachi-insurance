auto-install-peers=true
strict-peer-dependencies=false
# Disable pnpm 10's pre-flight dep status check that fails when build scripts
# are ignored. We've explicitly listed allowed build deps in package.json
# (pnpm.onlyBuiltDependencies). The pre-flight check is what makes
# `pnpm next dev` exit 1 with [ERR_PNPM_IGNORED_BUILDS].
verify-deps-before-run=false
